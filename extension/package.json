{
  "name": "pyflowlens",
  "displayName": "PyFlowLens",
  "description": "Visualize Python API execution flows, call graphs, CFG, and data flow. Static analysis + runtime tracing + change impact analysis for FastAPI projects.",
  "version": "0.2.0",
  "publisher": "dongkseo",
  "repository": {
    "type": "git",
    "url": "https://github.com/donggyun112/codecanvas"
  },
  "bugs": {
    "url": "https://github.com/donggyun112/codecanvas/issues"
  },
  "homepage": "https://github.com/donggyun112/codecanvas#readme",
  "keywords": [
    "python",
    "fastapi",
    "visualization",
    "call-graph",
    "control-flow",
    "data-flow",
    "static-analysis",
    "code-review",
    "impact-analysis"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:codecanvas.analyze",
    "onCommand:codecanvas.showFlow",
    "onCommand:codecanvas.showFunctionFlow",
    "onCommand:codecanvas.traceFlow",
    "onView:codecanvas.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codecanvas.analyze",
        "title": "CodeCanvas: Analyze Project"
      },
      {
        "command": "codecanvas.showFlow",
        "title": "CodeCanvas: Show Flow"
      },
      {
        "command": "codecanvas.showFunctionFlow",
        "title": "CodeCanvas: Analyze Function Flow"
      },
      {
        "command": "codecanvas.traceFlow",
        "title": "CodeCanvas: Trace Flow (Runtime)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codecanvas.showFunctionFlow",
          "when": "editorLangId == python",
          "group": "navigation@50"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codecanvas",
          "title": "CodeCanvas",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "codecanvas": [
        {
          "type": "webview",
          "id": "codecanvas.sidebar",
          "name": "Entry Points"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --dts --out-dir dist --external vscode",
    "watch": "tsup src/extension.ts --watch --format cjs --out-dir dist --external vscode",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
